// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed password for Admin
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id               String     @id @default(uuid())
  name             String
  phone            String?
  address          String?
  dateOfBirth      DateTime?
  role             String     // 목사, 장로, 권사, 집사, 성도
  registrationDate DateTime   @default(now())
  offerings        Offering[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Offering {
  id           String   @id @default(uuid())
  memberId     String
  member       Member   @relation(fields: [memberId], references: [id])
  date         DateTime
  amount       Float
  offeringType String   // 십일조, 감사헌금, 주일헌금, 건축헌금 등
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContentItem {
  id        String   @id @default(uuid())
  type      String   // e.g., "BULLETIN", "YOUTUBE_LINK", "NOTICE"
  title     String
  url       String?  // PDF/Image link for bulletin, YouTube URL
  content   String?  // Text content for notices
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
